{
  "name": "@iac/aws",
  "scripts": {
    "synth": "cdk synthesize --quiet",
    "diff": "cdk diff",
    "diff:ci": "npm run diff -- --ci",
    "deploy": "cdk deploy",
    "deploy:all": "npm run deploy -- --all",
    "deploy:ci": "npm run deploy:all -- --ci --app cdk.out --require-approval never --progress events",
    "lint": "eslint {lib,bin}/**/*.ts",
    "lint:fix": "npm run lint -- --fix"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hans-m-song/iac.git"
  },
  "workspaces": [
    "handlers"
  ],
  "dependencies": {
    "aws-cdk": "2.1033.0",
    "aws-cdk-lib": "2.232.1",
    "constructs": "10.4.3",
    "dotenv": "17.2.3",
    "source-map-support": "0.5.21",
    "tsx": "4.21.0",
    "typescript": "^5.8.0"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/aws-lambda": "8.10.152",
    "@types/node": "24.1.0",
    "@typescript-eslint/eslint-plugin": "8.38.0",
    "@typescript-eslint/parser": "8.38.0",
    "aws-lambda": "1.0.7",
    "eslint": "9.31.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.3",
    "eslint-plugin-react": "7.37.5",
    "prettier": "3.6.2"
  }
}
